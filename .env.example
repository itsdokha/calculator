# Подключения
DATABASE_URL=postgresql+psycopg://calc:calc@localhost:5432/calculator
REDIS_URL=redis://localhost:6379/0

# Бизнес-константы
MAX_CALCULATIONS_PER_USER=10
CATEGORIES_CACHE_TTL=3600
ACQUIRING_PCT=1.5

# Точки калибровки (открытые вопросы — см. data/reference/DATA-MODEL.md)
LOCALIZATION_INDEX=1.0          # ИЛ (C8)
BUYER_LOCATION_INDEX=0.0        # ИРП (C8)
HEAVY_GOODS_LOGISTICS_COEF=1.0  # коэффициент >25 кг (C2)
ACCEPTANCE_RUB=1.63            # приёмка за единицу (C9) — калибровочное значение под эталон
TARIFF_ANCHOR_DATE=2020-01-01   # якорь первого импорта тарифов (C3)

# Flask
FLASK_APP=wsgi.py
